generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id                                             String       @id
  name                                           String       @unique
  parentId                                       String?
  headId                                         String?
  status                                         UserStatus   @default(ACTIVE)
  createdAt                                      DateTime     @default(now())
  updatedAt                                      DateTime     @updatedAt
  assets                                         Asset[]
  head                                           User?        @relation("DepartmentHead", fields: [headId], references: [id])
  parent                                         Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children                                       Department[] @relation("DepartmentHierarchy")
  Transfer_Transfer_fromDepartmentIdToDepartment Transfer[]   @relation("Transfer_fromDepartmentIdToDepartment")
  Transfer_Transfer_toDepartmentIdToDepartment   Transfer[]   @relation("Transfer_toDepartmentIdToDepartment")
  employees                                      User[]
}

model User {
  id                                         String               @id
  email                                      String               @unique
  password                                   String
  name                                       String
  role                                       Role                 @default(EMPLOYEE)
  status                                     UserStatus           @default(ACTIVE)
  departmentId                               String?
  createdAt                                  DateTime             @default(now())
  updatedAt                                  DateTime             @updatedAt
  ActivityLog                                ActivityLog[]
  Allocation_Allocation_allocatedByIdToUser  Allocation[]         @relation("Allocation_allocatedByIdToUser")
  allocations                                Allocation[]
  Asset                                      Asset[]
  Audit                                      Audit[]
  AuditAsset                                 AuditAsset[]
  bookings                                   Booking[]
  headedDepartment                           Department[]         @relation("DepartmentHead")
  Maintenance_Maintenance_assignedToIdToUser Maintenance[]        @relation("Maintenance_assignedToIdToUser")
  Maintenance_Maintenance_raisedByIdToUser   Maintenance[]        @relation("Maintenance_raisedByIdToUser")
  Notification                               Notification[]
  resetTokens                                PasswordResetToken[]
  Transfer_Transfer_approvedByIdToUser       Transfer[]           @relation("Transfer_approvedByIdToUser")
  Transfer_Transfer_requestUserIdToUser      Transfer[]           @relation("Transfer_requestUserIdToUser")
  department                                 Department?          @relation(fields: [departmentId], references: [id])
}

model PasswordResetToken {
  id        String   @id
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id             String        @id
  assetTag       String        @unique
  name           String
  categoryId     String
  departmentId   String?
  assignedToId   String?
  location       String
  condition      String
  status         AssetStatus   @default(AVAILABLE)
  serialNumber   String?
  purchaseDate   DateTime?
  purchaseCost   Float?
  warrantyExpiry DateTime?
  imagePath      String?
  documentPaths  Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  allocations    Allocation[]
  User           User?         @relation(fields: [assignedToId], references: [id])
  category       Category      @relation(fields: [categoryId], references: [id])
  department     Department?   @relation(fields: [departmentId], references: [id])
  AuditAsset     AuditAsset[]
  Maintenance    Maintenance[]
  Transfer       Transfer[]
}

model Allocation {
  id                                  String           @id
  assetId                             String
  userId                              String
  allocatedById                       String
  allocatedAt                         DateTime         @default(now())
  returnedAt                          DateTime?
  dueDate                             DateTime?
  status                              AllocationStatus @default(ACTIVE)
  conditionOnReturn                   String?
  notes                               String?
  createdAt                           DateTime         @default(now())
  updatedAt                           DateTime
  User_Allocation_allocatedByIdToUser User             @relation("Allocation_allocatedByIdToUser", fields: [allocatedById], references: [id])
  asset                               Asset            @relation(fields: [assetId], references: [id])
  user                                User             @relation(fields: [userId], references: [id])
}

model Booking {
  id           String        @id
  resourceName String
  date         DateTime
  startTime    String
  endTime      String
  userId       String
  status       BookingStatus @default(UPCOMING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  user         User          @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id
  userId    String?
  action    String
  timestamp DateTime @default(now())
  module    String
  details   String?
  User      User?    @relation(fields: [userId], references: [id])
}

model Audit {
  id          String       @id
  title       String
  status      AuditStatus  @default(PENDING)
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  User        User         @relation(fields: [createdById], references: [id])
  AuditAsset  AuditAsset[]
}

model AuditAsset {
  id           String           @id
  auditId      String
  assetId      String
  status       AuditAssetStatus
  notes        String?
  verifiedAt   DateTime?
  verifiedById String?
  Asset        Asset            @relation(fields: [assetId], references: [id])
  Audit        Audit            @relation(fields: [auditId], references: [id])
  User         User?            @relation(fields: [verifiedById], references: [id])
}

model Category {
  id        String   @id
  name      String   @unique
  fields    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime
  assets    Asset[]
}

model Maintenance {
  id                                  String              @id
  assetId                             String
  raisedById                          String
  assignedToId                        String?
  priority                            MaintenancePriority @default(LOW)
  status                              MaintenanceStatus   @default(PENDING)
  description                         String
  notes                               String?
  createdAt                           DateTime            @default(now())
  updatedAt                           DateTime
  Asset                               Asset               @relation(fields: [assetId], references: [id])
  User_Maintenance_assignedToIdToUser User?               @relation("Maintenance_assignedToIdToUser", fields: [assignedToId], references: [id])
  User_Maintenance_raisedByIdToUser   User                @relation("Maintenance_raisedByIdToUser", fields: [raisedById], references: [id])
}

model Notification {
  id        String   @id
  userId    String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])
}

model Transfer {
  id                                               String        @id
  assetId                                          String
  requestUserId                                    String
  fromDepartmentId                                 String?
  toDepartmentId                                   String
  approvedById                                     String?
  status                                           RequestStatus @default(PENDING)
  createdAt                                        DateTime      @default(now())
  updatedAt                                        DateTime
  User_Transfer_approvedByIdToUser                 User?         @relation("Transfer_approvedByIdToUser", fields: [approvedById], references: [id])
  Asset                                            Asset         @relation(fields: [assetId], references: [id])
  Department_Transfer_fromDepartmentIdToDepartment Department?   @relation("Transfer_fromDepartmentIdToDepartment", fields: [fromDepartmentId], references: [id])
  User_Transfer_requestUserIdToUser                User          @relation("Transfer_requestUserIdToUser", fields: [requestUserId], references: [id])
  Department_Transfer_toDepartmentIdToDepartment   Department    @relation("Transfer_toDepartmentIdToDepartment", fields: [toDepartmentId], references: [id])
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum AuditAssetStatus {
  VERIFIED
  MISSING
  DAMAGED
}

enum AuditStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

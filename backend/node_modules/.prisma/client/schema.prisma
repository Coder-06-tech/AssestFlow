datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum AuditAssetStatus {
  VERIFIED
  MISSING
  DAMAGED
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  password         String
  name             String
  role             Role         @default(EMPLOYEE)
  status           UserStatus   @default(ACTIVE)
  departmentId     String?
  department       Department?  @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  headOfDepartment Department[] @relation("DepartmentHead")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  allocatedAssets     Asset[]        @relation("AssetAssignee")
  allocations         Allocation[]   @relation("AllocationUser")
  actionAllocations   Allocation[]   @relation("AllocationCreator")
  transfers           Transfer[]     @relation("TransferRequester")
  approvedTransfers   Transfer[]     @relation("TransferApprover")
  bookings            Booking[]
  raisedMaintenance   Maintenance[]  @relation("MaintenanceRaiser")
  assignedMaintenance Maintenance[]  @relation("MaintenanceTechnician")
  createdAudits       Audit[]        @relation("AuditCreator")
  verifiedAssets      AuditAsset[]   @relation("Auditor")
  notifications       Notification[]
  activityLogs        ActivityLog[]
}

model Department {
  id        String       @id @default(uuid())
  name      String       @unique
  parentId  String?
  parent    Department?  @relation("SubDepartments", fields: [parentId], references: [id])
  subDept   Department[] @relation("SubDepartments")
  headId    String?
  head      User?        @relation("DepartmentHead", fields: [headId], references: [id])
  status    UserStatus   @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  employees     User[]     @relation("EmployeeDepartment")
  assets        Asset[]
  transfersFrom Transfer[] @relation("TransferFromDept")
  transfersTo   Transfer[] @relation("TransferToDept")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  fields    Json? // Category-specific fields, e.g. [{"name": "RAM", "type": "string"}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets Asset[]
}

model Asset {
  id             String      @id @default(uuid())
  assetTag       String      @unique // e.g. AF-0001
  name           String
  categoryId     String
  category       Category    @relation(fields: [categoryId], references: [id])
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  assignedToId   String?
  assignedTo     User?       @relation("AssetAssignee", fields: [assignedToId], references: [id])
  location       String
  condition      String
  status         AssetStatus @default(AVAILABLE)
  serialNumber   String?
  purchaseDate   DateTime?
  purchaseCost   Float?
  warrantyExpiry DateTime?
  imagePath      String?
  documentPaths  Json? // JSON array of file paths
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  allocations Allocation[]
  transfers   Transfer[]
  maintenance Maintenance[]
  auditAssets AuditAsset[]
}

model Allocation {
  id                String           @id @default(uuid())
  assetId           String
  asset             Asset            @relation(fields: [assetId], references: [id])
  userId            String
  user              User             @relation("AllocationUser", fields: [userId], references: [id])
  allocatedById     String
  allocatedBy       User             @relation("AllocationCreator", fields: [allocatedById], references: [id])
  allocatedAt       DateTime         @default(now())
  returnedAt        DateTime?
  dueDate           DateTime?
  status            AllocationStatus @default(ACTIVE)
  conditionOnReturn String?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Transfer {
  id               String        @id @default(uuid())
  assetId          String
  asset            Asset         @relation(fields: [assetId], references: [id])
  requestUserId    String
  requestUser      User          @relation("TransferRequester", fields: [requestUserId], references: [id])
  fromDepartmentId String?
  fromDepartment   Department?   @relation("TransferFromDept", fields: [fromDepartmentId], references: [id])
  toDepartmentId   String
  toDepartment     Department    @relation("TransferToDept", fields: [toDepartmentId], references: [id])
  approvedById     String?
  approvedBy       User?         @relation("TransferApprover", fields: [approvedById], references: [id])
  status           RequestStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Booking {
  id           String        @id @default(uuid())
  resourceName String
  date         DateTime
  startTime    String // e.g. "09:00"
  endTime      String // e.g. "10:30"
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  status       BookingStatus @default(UPCOMING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Maintenance {
  id           String              @id @default(uuid())
  assetId      String
  asset        Asset               @relation(fields: [assetId], references: [id])
  raisedById   String
  raisedBy     User                @relation("MaintenanceRaiser", fields: [raisedById], references: [id])
  assignedToId String?
  assignedTo   User?               @relation("MaintenanceTechnician", fields: [assignedToId], references: [id])
  priority     MaintenancePriority @default(LOW)
  status       MaintenanceStatus   @default(PENDING)
  description  String
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Audit {
  id          String      @id @default(uuid())
  title       String
  status      AuditStatus @default(PENDING)
  createdById String
  createdBy   User        @relation("AuditCreator", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  auditAssets AuditAsset[]
}

model AuditAsset {
  id           String           @id @default(uuid())
  auditId      String
  audit        Audit            @relation(fields: [auditId], references: [id])
  assetId      String
  asset        Asset            @relation(fields: [assetId], references: [id])
  status       AuditAssetStatus
  notes        String?
  verifiedAt   DateTime?
  verifiedById String?
  verifiedBy   User?            @relation("Auditor", fields: [verifiedById], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  type      String // e.g. "INFO", "WARNING", "SUCCESS"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  timestamp DateTime @default(now())
  module    String // e.g. "ASSETS", "BOOKINGS", "MAINTENANCE"
  details   String?
}
